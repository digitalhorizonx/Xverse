# Development template. Copy to .env for use with docker-compose.dev.yml
# (or plain `npm run dev`). Never commit the real .env file.
#
# See .env.staging.example / .env.production.example for those environments.

# Inlined into the client bundle at build time. Local dev doesn't need a
# real domain — the app falls back sensibly either way.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Never index a local dev server.
NEXT_PUBLIC_ALLOW_INDEXING=false
