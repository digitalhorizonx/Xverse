# Development template. Copy to .env for use with docker-compose.dev.yml
# (or plain `npm run dev`). Never commit the real .env file.
#
# See .env.staging.example / .env.production.example for those environments.

# Inlined into the client bundle at build time. Local dev doesn't need a
# real domain — the app falls back sensibly either way.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Never index a local dev server.
NEXT_PUBLIC_ALLOW_INDEXING=false

# --- V2 admin console (Phase 1) ---------------------------------------------
# Local SQLite file (gitignored). Defaults to ./.data/xverse.db if unset.
DATABASE_PATH=./.data/xverse.db
# Any 32+ char string is fine for local dev.
SESSION_SECRET=dev-only-session-secret-change-me-0123456789
# Local first-admin bootstrap (created on first `npm run dev` boot).
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=local-dev-password
