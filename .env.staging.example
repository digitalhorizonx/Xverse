# Staging template for the "xverse" product. On the VPS, this becomes
# /opt/horizonx/products/xverse/staging/.env — see DEPLOYMENT.md for the
# HorizonX deployment standard (defined in full in the Xability repo).

# --- Build-time app config -------------------------------------------------
# Inlined into the client bundle at build time via Docker build-args (see
# .github/workflows/deploy.yml) — NOT read at container runtime.
# Domain follows the HorizonX convention: <product>-staging.horizonx.site
NEXT_PUBLIC_SITE_URL=https://xverse-staging.horizonx.site
# Keep "false" on staging so search engines don't index it.
NEXT_PUBLIC_ALLOW_INDEXING=false

# --- Runtime / docker-compose config ---------------------------------------
IMAGE=ghcr.io/digitalhorizonx/xverse
IMAGE_TAG=staging-latest
# Local port the app container's port 3000 is bound to (nginx proxies to this).
APP_PORT=3000
