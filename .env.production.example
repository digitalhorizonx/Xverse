# Production template for the "xverse" product. On the VPS, this becomes
# /opt/horizonx/products/xverse/production/.env — see DEPLOYMENT.md for the
# HorizonX deployment standard (defined in full in the Xability repo).

# --- Build-time app config -------------------------------------------------
# Inlined into the client bundle at build time via Docker build-args (see
# .github/workflows/deploy.yml) — NOT read at container runtime.
# Domain follows the HorizonX convention: <product>.horizonx.site
NEXT_PUBLIC_SITE_URL=https://xverse.horizonx.site
# Unset (or "true") in production so it's indexed normally.
NEXT_PUBLIC_ALLOW_INDEXING=true

# --- Runtime / docker-compose config ---------------------------------------
IMAGE=ghcr.io/digitalhorizonx/xverse
IMAGE_TAG=production-latest
# Local port the app container's port 3000 is bound to (nginx proxies to this).
APP_PORT=3000

# --- V2 admin console (Phase 1) ---------------------------------------------
# SQLite lives on the xverse-data volume; the default matches the image.
DATABASE_PATH=/data/xverse.db
# Session-token pepper. REQUIRED. Generate with: openssl rand -base64 48
# Rotating it signs everyone out (sessions become unverifiable) — safe.
SESSION_SECRET=
# One-time first-admin bootstrap: set BOTH for the first deploy only; the
# account is created only when the users table is empty. Remove both values
# after the first successful login.
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
